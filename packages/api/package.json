{
  "name": "@castle-budget/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc prisma/seed.ts --outDir dist/prisma --target ES2022 --module commonjs --moduleResolution node --esModuleInterop --skipLibCheck --types node",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "dotenv -e ../../.env -- sh -c 'TEST_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/castle_budget_test vitest run'",
    "test:watch": "dotenv -e ../../.env -- sh -c 'TEST_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/castle_budget_test vitest'",
    "lint": "eslint src --max-warnings=0"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^6.0.0",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "fastify": "^5.8.5",
    "prisma": "^5.14.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.2.1",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
}
