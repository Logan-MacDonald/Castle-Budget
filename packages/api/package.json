{
  "name": "@castle-budget/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "test": "dotenv -e ../../.env -- sh -c 'TEST_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/castle_budget_test vitest run'",
    "test:watch": "dotenv -e ../../.env -- sh -c 'TEST_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5433/castle_budget_test vitest'"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^5.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "fastify": "^4.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.14.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  }
}
