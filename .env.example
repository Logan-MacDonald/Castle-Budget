# ── Castle Budget Environment ─────────────────────────────────────────────────
# Copy this to .env and fill in values before first run.
# NEVER commit .env to version control.

# ── Required secrets — generate with: openssl rand -hex 32 ───────────────────
JWT_SECRET=replace-with-openssl-rand-hex-32
COOKIE_SECRET=replace-with-openssl-rand-hex-32

# ── App config ────────────────────────────────────────────────────────────────
APP_DOMAIN=budget.home        # LAN hostname (set in router/hosts DNS)
NODE_ENV=production
# Set to "true" only when serving over HTTPS (e.g., Tailscale Serve,
# Caddy/letsencrypt). With Secure=true on plain HTTP the browser drops
# the auth cookies and login can't persist.
COOKIE_SECURE=false

# ── Postgres ──────────────────────────────────────────────────────────────────
# Generate a password with: openssl rand -hex 24
POSTGRES_DB=castle_budget
POSTGRES_USER=castle
POSTGRES_PASSWORD=replace-with-openssl-rand-hex-24

# DATABASE_URL is derived in docker-compose.yml from the values above.
# For host-side tools (Prisma Studio, migrations from dev VM shell), uncomment.
# Host port is 5433 because the dev VM has a system postgres on 5432.
# DATABASE_URL=postgresql://castle:PASSWORD@localhost:5433/castle_budget

# ── Seed passwords (used only on first db:seed run) ──────────────────────────
# Change these immediately after first login
ADMIN_SEED_PASSWORD=Logan-change-me-now!
MEMBER_SEED_PASSWORD=Carla-change-me-now!

# ── Tailscale sidecar (joins the budget app to your tailnet) ─────────────────
# Reusable auth key from https://login.tailscale.com/admin/settings/keys
# (ephemeral=optional; tags help with ACLs). The sidecar shares its
# network namespace with the edge nginx, so the app is reachable via
# the tailnet IP/MagicDNS hostname AND via the LAN port 80.
TAILSCALE_AUTHKEY=tskey-auth-replace-me
TAILSCALE_HOSTNAME=castle-budget
